# =============================================================================
# agent-core-orchestrator — environment template
# Copy to `.env` and fill in only the providers you intend to use.
# =============================================================================

# --- Server -----------------------------------------------------------------
# Production deployment checklist:
#   * Keep AGENTCORE_HOST=127.0.0.1 unless the orchestrator is behind a
#     reverse proxy that adds auth (nginx + basic auth, ALB + IAM, etc.).
#   * Always set AGENTCORE_API_TOKEN when the listen address is reachable
#     by anything other than `localhost`. Mutating endpoints (/run,
#     /handoff, /signal, /wiki/refresh) require it once set.
#   * Never expose the orchestrator on 0.0.0.0 without both the token AND
#     a trusted proxy in front of it.
AGENTCORE_HOST=127.0.0.1
AGENTCORE_PORT=8088
AGENTCORE_LOG_LEVEL=info
# Bearer token required by mutating HTTP endpoints when set. Empty = dev mode.
AGENTCORE_API_TOKEN=

# --- Agent library ----------------------------------------------------------
# Folder watched for hot-reloaded role definitions.
AGENTCORE_AGENTS_DIR=./agents

# --- Postgres / pgvector ----------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=agentcore
PGUSER=agentcore
PGPASSWORD=agentcore

# --- Embeddings (in-process via fastembed) ----------------------------------
# Tiny model, no external server. First call lazily downloads weights.
AGENTCORE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# --- Reranking (optional; in-process cross-encoder) ------------------------
AGENTCORE_ENABLE_RERANK=true
AGENTCORE_RERANK_MODEL=mixedbread-ai/mxbai-rerank-xsmall-v1

# --- LLM providers (set what you need) --------------------------------------
# Resolution rule: each agent.md declares its preferred `llm.provider`. If that
# provider's key isn't set in this file, the orchestrator falls back to the
# first provider in AGENTCORE_PROVIDER_PRIORITY whose creds are populated.
# Default order puts z.ai at the top, then Anthropic, then Bedrock, then Azure.
# Reorder this list to change the fallback preference.
AGENTCORE_PROVIDER_PRIORITY=zai,anthropic,bedrock,azure_openai

# Per-provider fallback model (used only when we resolve to a different
# provider than the agent declared, since model identifiers don't translate
# across vendors). Override per-deployment as needed.
AGENTCORE_DEFAULT_MODEL_ZAI=glm-4.6
AGENTCORE_DEFAULT_MODEL_ANTHROPIC=claude-sonnet-4-6
AGENTCORE_DEFAULT_MODEL_BEDROCK=moonshot.kimi-k2-thinking
AGENTCORE_DEFAULT_MODEL_AZURE_OPENAI=gpt-4o

# Per-call timeout & retry policy (Anthropic / Azure / z.ai; boto3 owns Bedrock).
AGENTCORE_LLM_TIMEOUT_SECONDS=300
AGENTCORE_LLM_MAX_RETRIES=3
AGENTCORE_LLM_MAX_CONCURRENCY=4

# z.ai (Zhipu) — OpenAI-compatible. Top priority by default.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Anthropic
ANTHROPIC_API_KEY=

# AWS Bedrock — supports long-lived API keys (preferred for agents) OR the
# standard AWS env/profile chain. Set AWS_BEARER_TOKEN_BEDROCK for the API
# key path; boto3 picks it up automatically. The provider counts as
# "configured" if any of: AWS_BEARER_TOKEN_BEDROCK, AWS_PROFILE,
# AWS_ACCESS_KEY_ID, AWS_SESSION_TOKEN.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
AWS_PROFILE=

# Azure OpenAI (set both the API key AND endpoint to count as configured)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Optional integrations (host-credentialed) ------------------------------
# Adapters ride on the equivalent CLI already installed and authenticated on
# the host. If a flag is true but the CLI is missing/unauthenticated, the
# adapter is listed as unavailable in `agentcore doctor` and never fires.
#
#   GitHub : `gh auth status`
#   AWS    : `aws sts get-caller-identity`
#   Azure  : `az account show`
#
AGENTCORE_ENABLE_GITHUB=false
AGENTCORE_ENABLE_AWS=false
AGENTCORE_ENABLE_AZURE=false

# Periodic background scan: Ops walks repo + (if enabled) cloud + CI surfaces.
AGENTCORE_ENABLE_SCHEDULED_SCANS=false
AGENTCORE_SCHEDULED_SCAN_INTERVAL_SECONDS=900

# Graphify (in-process code knowledge graph; native Python).
# Returns from graphify.impact()/context() are merged into the operational
# graph after every successful agent hop (the enrichment loop).
AGENTCORE_ENABLE_GRAPHIFY=true
AGENTCORE_GRAPHIFY_REPO_ROOT=.

# --- Sandbox & multi-project ------------------------------------------------
# Where agent shell-outs execute. host=run on orchestrator host; docker=wrap
# in `docker exec` against AGENTCORE_SANDBOX_IMAGE. The orchestrator itself
# can run on host or in a container independent of this setting.
AGENTCORE_SANDBOX_MODE=host
AGENTCORE_SANDBOX_IMAGE=python:3.13-slim

# Tag for traces/metrics when one orchestrator serves multiple projects.
AGENTCORE_PROJECT_NAME=default

# --- Living wiki (codebase living-doc, retrieval-first) ---------------------
# Off by default. When enabled, the wikist agent maintains markdown pages
# under AGENTCORE_WIKI_ROOT and indexes them in pgvector under collection
# `wiki:<project>:<branch>`. The four shipped roles already declare `wiki`
# in their `knowledge.rag_collections`, so once enabled they retrieve
# wiki context on every hop without code changes.
#
# CLI:   `agentcore wiki rebuild`        — bulk-seed module pages
#        `agentcore wiki search "..."`   — semantic search
#        `agentcore wiki link [tool]`    — mirror to claude/copilot/cursor
#        `agentcore wiki install-hook`   — git post-commit incremental refresh
# HTTP:  GET /wiki, /wiki/{path}, /wiki/search, POST /wiki/refresh
AGENTCORE_ENABLE_WIKI=true
AGENTCORE_WIKI_ROOT=.agentcore/wiki
AGENTCORE_WIKI_CURATOR_MODEL=glm-4.6
AGENTCORE_WIKI_MAX_CHANGED_PATHS=200
